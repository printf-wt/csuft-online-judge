DB_URL=jdbc:mysql://mysql:3306/csuft_oj?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=true
DB_USERNAME=csuft_oj
DB_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRATION_SECONDS=900
JWT_REFRESH_EXPIRATION_SECONDS=604800
JWT_REFRESH_COOKIE_SECURE=true
MANAGEMENT_PORT=8081
FORWARD_HEADERS_STRATEGY=NATIVE
LOG_FILE=/var/log/csuft-oj/application.log
TESTCASE_PATH=/var/lib/csuft-oj/testcases
JUDGE_TEMP_PATH=/var/lib/csuft-oj/judge-temp
JUDGE_QUEUE_CAPACITY=1000
JUDGE_WORKER_COUNT=2
JUDGE_EXECUTION_MODE=SANDBOX
JUDGE_SANDBOX_COMMAND=/usr/local/bin/csuft-oj-sandbox
